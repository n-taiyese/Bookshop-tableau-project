      <aliases enabled='yes' />
      <column caption='Auth ID' datatype='string' name='[AuthID]' role='dimension' type='nominal' />
      <column caption='Book ID' datatype='string' name='[BookID]' role='dimension' type='nominal' />
      <column caption='Quarter Label' datatype='string' name='[Calculation_1084400817610755]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='&quot;Q&quot; + STR(DATEPART(&apos;quarter&apos;, [Sale Date]))' />
      </column>
      <column caption='Is Discounted' datatype='boolean' name='[Calculation_1084400818753540]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='NOT ISNULL([Discount])' />
        <aliases>
          <alias key='false' value='Full Price' />
          <alias key='true' value='Discounted' />
        </aliases>
      </column>
      <column caption='Author Name' datatype='string' name='[Calculation_1732288015515649]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[First Name]+&quot; &quot;+[Last Name]' />
      </column>
      <column caption='Total Reviews' datatype='integer' name='[Calculation_2043724878266368]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='COUNT([ReviewID])' />
      </column>
      <column caption='Average Rating' datatype='real' name='[Calculation_2043724879060993]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='AVG([Rating])' />
      </column>
      <column caption='% of 5 Star Reviews' datatype='real' name='[Calculation_2043724879679490]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM(IF  [Rating]=5 THEN 1 ELSE 0 END)/COUNT([ReviewID])' />
      </column>
      <column caption='Total Checkouts' datatype='integer' name='[Calculation_2043724880920579]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Number of Checkouts])' />
      </column>
      <column caption='Rating Band' datatype='string' name='[Calculation_2043724885295108]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Rating]=5 THEN &quot;5 — Excellent&quot; ELSEIF [Rating]=4 THEN &quot;4 — Good&quot; ELSEIF [Rating]=3 THEN &quot;3 — Average&quot; ELSEIF [Rating]=2 THEN &quot;2 — Poor&quot; ELSE &quot;1 — Very Poor&quot; END' />
        <aliases>
          <alias key='&quot;1 — Very Poor&quot;' value='1*' />
          <alias key='&quot;2 — Poor&quot;' value='2' />
          <alias key='&quot;3 — Average&quot;' value='3' />
          <alias key='&quot;4 — Good&quot;' value='4' />
          <alias key='&quot;5 — Excellent&quot;' value='5' />
        </aliases>
      </column>
      <column caption='Total Checkouts per Book' datatype='integer' name='[Calculation_2043724885528581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [BookID] : SUM([Number of Checkouts])}' />
      </column>
      <column caption='Checkout Month Name' datatype='string' name='[Calculation_2043724886007814]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='DATENAME(&apos;month&apos;, MAKEDATE(2000,[CheckoutMonth],1))' />
      </column>
      <column caption='Active Genre Label' datatype='string' name='[Calculation_2043724893712391]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Total Reviews — &quot; + &#13;&#10;IF COUNTD([Genre]) = 8 &#13;&#10;THEN &quot;All Genres&quot; &#13;&#10;ELSE MIN([Genre]) &#13;&#10;END' />
      </column>
      <column caption='Active Genre Label - Avg Rating' datatype='string' name='[Calculation_2043724901826568]' role='measure' type='nominal'>
        <calculation class='tableau' formula='&quot;Avg Rating - &quot; + IFNULL(MIN([Genre]), &quot;All Genres&quot;)' />
      </column>
      <column caption='Revenue' datatype='real' name='[Calculation_2067915985661952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [ISBN (Sales Q1+)] : MIN([Price]) * COUNT([ItemID]) }' />
      </column>
      <column caption='Checkout Month' datatype='integer' name='[CheckoutMonth]' role='dimension' type='quantitative' />
